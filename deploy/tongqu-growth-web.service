[Unit]
Description=Tongqu Growth Web
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/var/www/tongqu-growth-web
Environment=NODE_ENV=production
Environment=PORT=3000
ExecStart=/usr/bin/npm start -- --hostname 0.0.0.0 --port 3000
Restart=always
RestartSec=5
KillSignal=SIGINT
SyslogIdentifier=tongqu-growth-web

[Install]
WantedBy=multi-user.target
